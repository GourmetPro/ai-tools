function allCommands() {
  return new Set(['list-backends', ...Object.keys(postgresAdapter.commands), ...Object.keys(githubAdapter.commands)]);
}

function helpTextFor(command) {
  return (commandDocs[command] || GENERAL_HELP).trim();
}

function printHelp(command, stream = process.stdout) {
  stream.write(`${helpTextFor(command)}\n`);
}

function printUsageError(message) {
  if (message) console.error(`tools/backlog: ${message}`);
  printHelp(null, process.stderr);
  process.exit(2);
}

// --- hidden test helpers ------------------------------------------------------
function maybeRunTestHelper(cmd, rest) {
  if (process.env.BACKLOG_TEST_HELPERS !== '1') return false;
  if (cmd === '__test-github-id') {
    const args = parseArgs(rest);
    require_(args, ['repo', 'number']);
    process.stdout.write(`${githubIdFor(args.repo, args.number)}\n`);
    return true;
  }
  if (cmd === '__test-frontmatter-roundtrip') {
    const args = parseArgs(rest);
    require_(args, ['file', 'set']);
    const parsed = parseFrontmatter(fs.readFileSync(args.file, 'utf8'));
    let updates;
    try { updates = JSON.parse(args.set); } catch (e) { fail(`--set is not valid JSON: ${e.message}`); }
    process.stdout.write(formatFrontmatter({ ...parsed.meta, ...updates }, parsed.body));
    return true;
  }
  return false;
}

// --- main --------------------------------------------------------------------
async function main() {
  const parsedGlobal = parseGlobalArgs(process.argv.slice(2));
  const [cmd, ...rest] = parsedGlobal.rest;
  const commands = allCommands();
  if (!cmd || cmd === '-h' || cmd === '--help') {
    if (!cmd) printUsageError();
    printHelp();
    return;
  }
  if (maybeRunTestHelper(cmd, rest)) return;
  if (cmd === 'help') {
    if (rest.length > 1) printUsageError('usage: backlog help [command]');
    const helpCommand = rest[0];
    if (helpCommand && !commands.has(helpCommand)) printUsageError(`unknown command: ${helpCommand}`);
    printHelp(helpCommand);
    return;
  }
  if (!commands.has(cmd)) printUsageError(`unknown command: ${cmd}`);
  if (rest.includes('-h') || rest.includes('--help')) {
    printHelp(cmd);
    return;
  }
  if (cmd === 'list-backends') {
    const args = parseArgs(rest);
    const keys = Object.keys(args);
    if (keys.length) fail('list-backends does not accept flags');
    console.log(JSON.stringify(listBackendConfigs(), null, 2));
    return;
  }

  const backend = selectBackendConfig(parsedGlobal.globals);
  const adapter = adapters.get(backend.type);
  if (!adapter) fail(`unsupported backend type "${backend.type}" for backend ${backend.name}`);
  const command = adapter.commands[cmd];
  if (!command) fail(`command ${cmd} is not supported by backend ${backend.name}`);
  const args = parseArgs(rest);
  for (const k of Object.keys(args)) {
    if (!command.flags.includes(k)) {
      fail(`unknown flag --${k} for ${cmd} (allowed: ${command.flags.map((f) => '--' + f).join(' ') || 'none'})`);
    }
  }
  const result = await command.fn(args, backend);
  console.log(JSON.stringify(result, null, 2));
}

main().catch((e) => {
  fail(e && e.message ? e.message : String(e));
});
