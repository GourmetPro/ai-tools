const GENERAL_HELP = `
Usage: backlog <command> [--flags]
       backlog help <command>
       backlog <command> --help

Purpose:
  Use this CLI when an AI or human needs to inspect or update the shared GourmetPro backlog
  from any terminal, including repos that do not contain the backlog source code.
  The CLI mirrors the /mcp/backlog MCP tools and talks directly to the configured
  Postgres database through psql.

Commands:
  list-repos
      Show registered repositories and their short slugs.
  create-repo --slug <org/repo> --short-slug <short> --display-name <name>
      Register a repository for backlog ownership.
  list-items [--repo <org/repo>] [--workstream <name>] [--status <csv>]
      Search backlog items with filters.
  get-item --id <item-id>
      Read one item and the items it blocks.
  summarize [--workstream <name>] [--repo <org/repo>]
      Count items by workstream and status.
  create-item --repo <org/repo> --workstream <name> --title <text> --type engineering|spec_pending_impl|wiki_ops
      Create a tracked backlog item.
  update-item --id <item-id> [--status queued|in_progress|blocked|done|abandoned]
      Update status, priority, metadata, dependencies, and notes.

AI workflow:
  1. Run backlog list-repos to discover valid --repo values.
  2. Run backlog list-items or backlog summarize before creating new work.
  3. Use backlog get-item before changing an item you did not just create.
  4. Use create-item for durable follow-up work that should survive the chat.
  5. Use update-item to record progress, branches, blockers, completion, and links.

Configuration:
  Reads DATABASE_URL from ~/.config/ai-tools/backlog.conf by default.
  Set BACKLOG_CONFIG to use another config file.
  Set BACKLOG_DATABASE_URL for a one-off session override.
  The config file should contain: DATABASE_URL='postgres://user:pass@host/db'

Output:
  Successful commands print pretty JSON to stdout.
  Failures print one line to stderr and exit non-zero.

links JSON:
  --links accepts a JSON array. Supported objects:
  [{"kind":"spec","repo":"org/repo","path":"docs/spec.md"}]
  [{"kind":"brief","repo":"org/repo","path":"briefs/customer.md"}]
  [{"kind":"pr","url":"https://github.com/org/repo/pull/123"}]
  [{"kind":"commit","repo":"org/repo","sha":"abcdef1"}]
  [{"kind":"url","url":"https://example.com/context"}]

Examples:
  backlog list-repos
  backlog list-items --repo GourmetPro/ai-tools --status queued,in_progress
  backlog create-item --repo GourmetPro/ai-tools --workstream tooling --title "Document backlog CLI help" --type engineering
  backlog update-item --id ai-tools--tooling--document-backlog-cli --status done --progress-note "Documented CLI help"

Try: backlog --help
Try: backlog help <command>
`.trim();

function helpTextFor(command) {
  return (commandDocs[command] || GENERAL_HELP).trim();
}

function printHelp(command, stream = process.stdout) {
  stream.write(`${helpTextFor(command)}\n`);
}

function printUsageError(message) {
  if (message) console.error(`tools/backlog: ${message}`);
  printHelp(null, process.stderr);
  process.exit(2);
}

const [cmd, ...rest] = process.argv.slice(2);
if (!cmd || cmd === '-h' || cmd === '--help') {
  if (!cmd) printUsageError();
  printHelp();
  process.exit(0);
}
if (cmd === 'help') {
  if (rest.length > 1) printUsageError('usage: backlog help [command]');
  const helpCommand = rest[0];
  if (helpCommand && !commands[helpCommand]) {
    printUsageError(`unknown command: ${helpCommand}`);
  }
  printHelp(helpCommand);
  process.exit(0);
}
if (!cmd || !commands[cmd]) {
  printUsageError(`unknown command: ${cmd}`);
}
if (rest.includes('-h') || rest.includes('--help')) {
  printHelp(cmd);
  process.exit(0);
}
const args = parseArgs(rest);
for (const k of Object.keys(args)) {
  if (!commands[cmd].flags.includes(k)) {
    fail(`unknown flag --${k} for ${cmd} (allowed: ${commands[cmd].flags.map((f) => '--' + f).join(' ') || 'none'})`);
  }
}
console.log(JSON.stringify(commands[cmd].fn(args), null, 2));
