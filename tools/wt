#!/usr/bin/env zsh
# wt - Prepare an isolated worktree, optionally launching Claude inside it.
#
# Install:
#   ./install/wt
#
# Usage: wt <name> [--from <branch>] [--claude [--model <model>] [--prompt "..."] [--tmux]]

usage() {
  print -r -- 'Usage: wt <name> [--from <branch>] [--claude [--model <model>] [--prompt "..."] [--tmux]]'
}

main() {
  emulate -L zsh
  setopt err_return pipe_fail

  local name=""
  local from_branch="main"
  local model=""
  local prompt=""
  local tmux=0
  local launch_claude=0
  local claude_option_used=0

  while (( $# )); do
    case "$1" in
      --from)
        from_branch="$2"
        shift 2
        ;;
      --model)
        model="$2"
        claude_option_used=1
        shift 2
        ;;
      --prompt)
        prompt="$2"
        claude_option_used=1
        shift 2
        ;;
      --tmux)
        tmux=1
        claude_option_used=1
        shift
        ;;
      --claude)
        launch_claude=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      -*)
        print -r -- "wt: unknown flag: $1" >&2
        return 1
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        else
          print -r -- "wt: unexpected argument: $1" >&2
          return 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$name" ]]; then
    usage >&2
    return 1
  fi

  if (( claude_option_used && ! launch_claude )); then
    print -r -- "wt: --model, --prompt, and --tmux require --claude" >&2
    return 1
  fi

  # Resolve main repo root (works from main repo or any worktree).
  local git_common
  git_common=$(git rev-parse --git-common-dir 2>/dev/null) || {
    print -r -- "wt: not inside a git repo" >&2
    return 1
  }
  # --git-common-dir returns a relative path when inside the main repo; make absolute.
  if [[ "$git_common" != /* ]]; then
    git_common="$PWD/$git_common"
  fi
  local repo_root
  repo_root=$(cd "$git_common/.." && pwd -P)

  local branch="worktree-${name}"
  local wt_path="$repo_root/.claude/worktrees/$name"

  # Worktree handling (idempotent).
  if [[ -d "$wt_path" ]]; then
    print -r -- "✓ Reusing worktree .claude/worktrees/$name (branch: $branch)"
  elif git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$repo_root" worktree add "$wt_path" "$branch" >/dev/null
    print -r -- "✓ Attached worktree .claude/worktrees/$name to existing branch $branch"
  else
    git -C "$repo_root" worktree add -b "$branch" "$wt_path" "$from_branch" >/dev/null
    print -r -- "✓ Created worktree .claude/worktrees/$name (branch: $branch, from: $from_branch)"
  fi

  # Sync secrets / local settings from main repo.
  local link src dst
  for link in .env .env.production .claude/settings.local.json; do
    src="$repo_root/$link"
    dst="$wt_path/$link"
    if [[ ! -e "$src" && ! -L "$src" ]]; then
      print -r -- "- $link (no source, skipped)"
      continue
    fi
    if [[ -e "$dst" || -L "$dst" ]]; then
      print -r -- "- $link (target exists, skipped)"
      continue
    fi
    mkdir -p "${dst:h}"
    ln -s "$src" "$dst"
    print -r -- "✓ Linked $link"
  done

  link=.env.local
  src="$repo_root/$link"
  dst="$wt_path/$link"
  if [[ ! -e "$src" ]]; then
    print -r -- "- $link (no source, skipped)"
  elif [[ -e "$dst" || -L "$dst" ]]; then
    print -r -- "- $link (target exists, skipped)"
  else
    cp -p "$src" "$dst"
    print -r -- "✓ Copied $link"
  fi

  # Defensive tmp/ prep.
  mkdir -p "$wt_path/tmp"
  print -r -- "✓ tmp/ ready"

  if (( ! launch_claude )); then
    print -r -- "→ Worktree ready: $wt_path"
    return 0
  fi

  # Terminal tab title.
  print -Pn "\e]0;cc:${name}\a"

  # Launch claude from the worktree dir.
  print -r -- "→ Launching claude (remote-control: $name)"
  cd "$wt_path"

  local -a claude_args
  claude_args=(--remote-control "$name" --name "$name")
  [[ -n "$model" ]] && claude_args+=(--model "$model")
  (( tmux )) && claude_args+=(--tmux)
  [[ -n "$prompt" ]] && claude_args+=("$prompt")

  command claude "${claude_args[@]}"
}

main "$@"
