#!/usr/bin/env sh
set -eu

usage() {
  cat <<'EOF'
Usage: install/backlog [--bin-dir DIR] [--config FILE] [--database-url URL] [--force]

Installs the backlog executable by symlinking tools/backlog into DIR.
Default DIR: $AI_TOOLS_BIN_DIR, or ~/.local/bin.
Default config: $BACKLOG_CONFIG, or $XDG_CONFIG_HOME/ai-tools/backlog.json, or ~/.config/ai-tools/backlog.json.

If the config file does not exist, the installer prompts for DATABASE_URL when
interactive. Press Enter to skip and create an editable backlog.json template.
EOF
}

die() {
  printf 'install/backlog: %s\n' "$1" >&2
  exit 2
}

bin_dir="${AI_TOOLS_BIN_DIR:-}"
config_path="${BACKLOG_CONFIG:-}"
legacy_config_path=""
database_url=""
write_config=0
force=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --bin-dir)
      [ "$#" -ge 2 ] || die '--bin-dir requires a value'
      bin_dir="$2"
      shift 2
      ;;
    --bin-dir=*)
      bin_dir="${1#--bin-dir=}"
      shift
      ;;
    --config)
      [ "$#" -ge 2 ] || die '--config requires a value'
      config_path="$2"
      shift 2
      ;;
    --config=*)
      config_path="${1#--config=}"
      shift
      ;;
    --database-url)
      [ "$#" -ge 2 ] || die '--database-url requires a value'
      database_url="$2"
      write_config=1
      shift 2
      ;;
    --database-url=*)
      database_url="${1#--database-url=}"
      write_config=1
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

if [ -z "$bin_dir" ]; then
  [ -n "${HOME:-}" ] || die 'HOME is not set; pass --bin-dir'
  bin_dir="$HOME/.local/bin"
fi

if [ -z "$config_path" ]; then
  if [ -n "${XDG_CONFIG_HOME:-}" ]; then
    config_path="$XDG_CONFIG_HOME/ai-tools/backlog.json"
    legacy_config_path="$XDG_CONFIG_HOME/ai-tools/backlog.conf"
  else
    [ -n "${HOME:-}" ] || die 'HOME is not set; pass --config'
    config_path="$HOME/.config/ai-tools/backlog.json"
    legacy_config_path="$HOME/.config/ai-tools/backlog.conf"
  fi
else
  legacy_config_path="$(dirname "$config_path")/backlog.conf"
fi

script_dir="$(CDPATH= cd "$(dirname "$0")" && pwd -P)"
repo_dir="$(CDPATH= cd "$script_dir/.." && pwd -P)"
tool_path="$repo_dir/tools/backlog"
target="$bin_dir/backlog"

[ -f "$tool_path" ] || die "missing tool: $tool_path"
mkdir -p "$bin_dir"
chmod +x "$tool_path"

if [ ! -f "$config_path" ] && [ "$write_config" -eq 0 ]; then
  if [ -t 0 ]; then
    printf 'DATABASE_URL (press Enter to skip): ' >&2
    IFS= read -r database_url
  fi
  write_config=1
fi

if [ "$write_config" -eq 1 ]; then
  if [ -e "$config_path" ] && [ "$force" -ne 1 ]; then
    die "$config_path already exists; pass --force to replace it"
  fi
fi

if [ -e "$target" ] || [ -L "$target" ]; then
  if [ -L "$target" ] && [ "$(readlink "$target")" = "$tool_path" ]; then
    rm -f "$target"
  elif [ "$force" -eq 1 ]; then
    rm -f "$target"
  else
    die "$target already exists; pass --force to replace it"
  fi
fi

ln -s "$tool_path" "$target"

if [ "$write_config" -eq 1 ]; then
  mkdir -p "$(dirname "$config_path")"
  umask 077
  tmp_config="$config_path.tmp.$$"
  {
    printf '{\n'
    printf '  "default": "gtm-console",\n'
    printf '  "backends": [\n'
    printf '    {\n'
    printf '      "name": "gtm-console",\n'
    printf '      "type": "postgres",\n'
    if [ -n "$database_url" ]; then
      node -e 'process.stdout.write(JSON.stringify(process.argv[1]))' "$database_url" > "$tmp_config.url"
      printf '      "databaseUrl": %s\n' "$(cat "$tmp_config.url")"
      rm -f "$tmp_config.url"
    else
      printf '      "databaseUrlEnv": "BACKLOG_DATABASE_URL"\n'
    fi
    printf '    },\n'
    printf '    {\n'
    printf '      "name": "github",\n'
    printf '      "type": "github-issues",\n'
    printf '      "tokenEnv": "GITHUB_TOKEN"\n'
    printf '    }\n'
    printf '  ]\n'
    printf '}\n'
  } > "$tmp_config"
  mv "$tmp_config" "$config_path"
  chmod 600 "$config_path"
fi

printf 'Installed backlog -> %s\n' "$target"
printf 'Backlog config: %s\n' "$config_path"
if [ -n "$legacy_config_path" ] && [ -f "$legacy_config_path" ]; then
  printf 'Note: existing legacy config remains supported: %s\n' "$legacy_config_path" >&2
fi

case ":${PATH:-}:" in
  *":$bin_dir:"*) ;;
  *) printf 'Note: %s is not currently on PATH.\n' "$bin_dir" >&2 ;;
esac
